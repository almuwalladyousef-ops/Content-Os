# Content OS home server (Mac mini) — copy to .env and fill in.
# Per the no-security policy this is a personal app: the ONLY secret is
# HOME_SERVER_SECRET, because Tailscale Funnel exposes this machine publicly.

PORT=3737
DATA_DIR=~/ContentOS-data

# Shared secret between the Vercel app and this server (any random string).
HOME_SERVER_SECRET=

# Optional: also sent by the heartbeat to the Vercel worker (may stay empty).
CRON_SECRET=

# The deployed web app this server heartbeats to.
POSTER_URL=https://contentos-flame.vercel.app

# LinkScribe local Whisper (jobs run on this machine)
LINKSCRIBE_WHISPER_MODEL=base
LINKSCRIBE_WHISPER_COMMAND=

# Vault board Google integration (unchanged from contentos-local-server)
GC_CLIENT_ID=
GC_CLIENT_SECRET=
GC_API_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_MAPS_API_KEY=

# Optional fallback if local Whisper fails
GROQ_API_KEY=
