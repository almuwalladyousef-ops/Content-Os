# ─────────────────────────────────────────────────────────────────────────────
# ContentOS environment — set these ONCE (locally in .env.local, and in Vercel).
# After this, connecting accounts is a single "Connect" click with nothing to paste.
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# Cookie encryption key. Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=

# Public origin of the app. Leave blank for local dev (auto-detected), set in prod.
# Example: https://contentos.vercel.app   (NO trailing slash)
NEXTAUTH_URL=

# ── Google  (YouTube upload · Drive · Analytics · Gmail notifications) ─────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth client (Web)
# Authorized redirect URI:  <NEXTAUTH_URL>/api/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── TikTok  (Content Posting API) ─────────────────────────────────────────────
# developers.tiktok.com → your app → Login Kit + Content Posting API
# Redirect URI:  <NEXTAUTH_URL>/api/auth/tiktok/callback
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Only the scopes your app is actually approved for. A "scope" error on the
# TikTok login screen means one of these is not enabled for your app.
# Default (posting only): user.info.basic,video.publish,video.upload
# Add video.list ONLY once approved (needed for TikTok analytics):
TIKTOK_SCOPES=

# ── Instagram  (ONE Instagram Login for ALL account types) ────────────────────
# developers.facebook.com → your app (the "personal" Meta app) → Instagram Login
# Redirect URI:  <NEXTAUTH_URL>/api/auth/instagram/callback
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Meta webhook verify token for DM automation (any string you also paste in the
# Meta dashboard). Webhook URL: <NEXTAUTH_URL>/api/dm/webhook
VERIFY_TOKEN=
ALLOW_UNVERIFIED_WEBHOOKS=true

# ── AI features (optional — captions, hashtags, transcript analysis) ──────────
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Home server (Mac mini) — file storage, readback, linkscribe, heartbeat ────
# The Tailscale Funnel URL of the mini, e.g. https://<machine>.<tailnet>.ts.net
HOME_SERVER_URL=
# Must match home-server/.env HOME_SERVER_SECRET (any random string).
HOME_SERVER_SECRET=

# ── Google Drive JSON database (service account) ──────────────────────────────
# One JSON file per app section, inside your Drive DB folder (share the folder
# with the service-account email). DRIVE_DB_<SECTION>_FILE_ID overrides lookup.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
DRIVE_DB_FOLDER_ID=
# Existing triggerdm db.json (reused as the "dm" section):
GOOGLE_DRIVE_FILE_ID=

# Optional shared secret for the schedule worker; leave empty to run unguarded.
CRON_SECRET=
